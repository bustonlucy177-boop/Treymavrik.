/* =====================================================
   TREY MAVRIK OFFICIAL WEBSITE
   Squarespace-inspired Minimal Design
===================================================== */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{

    font-family:'Inter',sans-serif;

    background:#ffffff;

    color:#111111;

    line-height:1.7;

    overflow-x:hidden;

}

/* ==========================
        Typography
========================== */

h1{

    font-size:4rem;

    font-weight:700;

    letter-spacing:8px;

    text-transform:uppercase;

}

h2{

    font-size:2.2rem;

    font-weight:600;

    margin-bottom:40px;

    letter-spacing:1px;

}

p{

    font-size:1rem;

    color:#555;

}

a{

    text-decoration:none;

    color:inherit;

}

/* ==========================
        Header
========================== */

header{

    position:fixed;

    top:0;

    left:0;

    width:100%;

    background:rgba(0,0,0,.75);

    backdrop-filter:blur(15px);

    display:flex;

    justify-content:space-between;

    align-items:center;

    padding:22px 8%;

    z-index:999;

}

.logo{

    color:#fff;

    font-size:1rem;

    font-weight:700;

    letter-spacing:4px;

}

nav ul{

    display:flex;

    list-style:none;

    gap:30px;

}

nav ul li a{

    color:#fff;

    font-size:.9rem;

    transition:.3s;

}

nav ul li a:hover{

    opacity:.65;

}

/* ==========================
        Hero
========================== */

.hero{

    position:relative;

    width:100%;

    height:100vh;

    background:url("../images/hero.jpg") center center/cover no-repeat;

    display:flex;

    justify-content:center;

    align-items:center;

    text-align:center;

}

.overlay{

    position:absolute;

    inset:0;

    background:rgba(0,0,0,.58);

}

.hero-content{

    position:relative;

    z-index:2;

    color:#fff;

}

.hero-content h1{

    margin-bottom:40px;

}

.button{

    display:inline-block;

    padding:16px 44px;

    border:1px solid #fff;

    color:#fff;

    font-size:.85rem;

    letter-spacing:2px;

    transition:.35s;

}

.button:hover{

    background:#fff;

    color:#000;

}

/* ==========================
      Main Sections
========================== */

section{

    padding:120px 8%;

}

.featured{

    background:#fff;

}

.music{

    background:#f8f8f8;

}

.videos{

    background:#fff;

}


.release-card img{

    width:100%;

    border-radius:6px;

    margin-bottom:35px;

}



/* ==========================
   Streaming Platforms
========================== */

.streaming-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:24px;
    margin-top:50px;
}

.streaming-grid a{
    display:flex;
    justify-content:center;
    align-items:center;
    padding:26px;
    background:#ffffff;
    border:1px solid #e5e5e5;
    color:#111;
    font-size:.95rem;
    font-weight:500;
    transition:all .3s ease;
}

.streaming-grid a:hover{
    background:#111;
    color:#fff;
    transform:translateY(-4px);
}

/* ==========================
   Videos
========================== */

#videoContainer{
    max-width:1000px;
    margin:0 auto;
    display:grid;
    gap:40px;
}

#videoContainer iframe{
    width:100%;
    aspect-ratio:16/9;
    border:none;
    border-radius:8px;
}

#videoContainer p{
    text-align:center;
    font-size:1rem;
    color:#666;
}

/* ==========================
   Concerts
========================== */

#concertContainer{
    max-width:900px;
    margin:0 auto;
    text-align:center;
}

.concert-card{
    border:1px solid #e6e6e6;
    padding:28px;
    margin-bottom:24px;
    transition:.3s ease;
}

.concert-card:hover{
    transform:translateY(-4px);
    box-shadow:0 12px 30px rgba(0,0,0,.08);
}

.concert-date{
    font-size:1.1rem;
    font-weight:600;
    margin-bottom:8px;
}

.concert-location{
    color:#666;
}

/* ==========================
   Socials
========================== */

.social-icons{
    display:flex;
    justify-content:center;
    align-items:center;
    gap:28px;
    flex-wrap:wrap;
    margin-top:40px;
}

.social-icons a{
    padding:14px 24px;
    border:1px solid #111;
    transition:.3s ease;
}

.social-icons a:hover{
    background:#111;
    color:#fff;
}

/* ==========================
   Footer
========================== */

footer{
    padding:40px 8%;
    text-align:center;
    border-top:1px solid #e5e5e5;
    background:#fff;
}

footer p{
    color:#666;
    font-size:.9rem;
    letter-spacing:.5px;
}

/* ==========================
   Responsive
========================== */

@media (max-width:992px){

    h1{
        font-size:3rem;
        letter-spacing:5px;
    }

    h2{
        font-size:1.9rem;
    }

    nav ul{
        gap:18px;
    }

}

@media (max-width:768px){

    header{
        flex-direction:column;
        gap:18px;
        padding:18px 6%;
    }

    nav ul{
        flex-wrap:wrap;
        justify-content:center;
        gap:14px;
    }

    h1{
        font-size:2.3rem;
        letter-spacing:3px;
    }

    h2{
        font-size:1.6rem;
    }

    section{
        padding:90px 6%;
    }

    .button{
        padding:14px 34px;
    }

}

@media (max-width:480px){

    h1{
        font-size:1.9rem;
    }

    h2{
        font-size:1.4rem;
    }

    .streaming-grid{
        grid-template-columns:1fr;
    }

}

.concerts{

    background:#f8f8f8;

}

.socials{

    background:#fff;

}

